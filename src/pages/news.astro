---
import Layout from '../layouts/Layout.astro';

const newsItems = [
  {
    date: '2026-04-29',
    title: 'TMPCS.EU – New Name, Same Excellence',
    content: 'We are excited to announce our rebranding to TMPCS.EU. While our name has changed, our commitment to precision, excellence, and European luxury watch distribution remains stronger than ever. Our team continues to deliver the same high-quality service and curated portfolio of exceptional timepieces that our partners have come to trust.',
  },
];
---

<Layout
  title="News | TMPCS.EU"
  description="Latest news and press releases from TMPCS.EU. Stay informed about our brand portfolio, partnerships, and company updates."
>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 bg-primary" aria-labelledby="news-heading">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-[#0a1f38]" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 id="news-heading" class="text-3xl sm:text-4xl md:text-5xl font-bold text-white tracking-tight">
        News & Press Releases
      </h1>
      <p class="mt-4 text-lg text-white/70 max-w-2xl">
        The latest updates from TMPCS.EU — announcements, partnerships, and insights from the world of luxury watch distribution.
      </p>
    </div>
  </section>

  <!-- News List -->
  <section class="py-24 bg-background" aria-label="News articles">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        {newsItems.map((item) => (
          <article class="bg-white border border-secondary/20 rounded-xl p-8 md:p-10 hover:shadow-lg transition-shadow">
            <time 
              class="inline-block text-sm font-medium text-secondary bg-secondary/10 px-3 py-1 rounded-full mb-4" 
              datetime={item.date}
            >
              {new Date(item.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">
              {item.title}
            </h2>
            <p class="text-text/80 leading-relaxed text-lg">
              {item.content}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
