---
import Layout from '../layouts/Layout.astro';

const brandImageMap: Record<string, string> = {
  squale: '/squale.jpg',
  marathon: '/marathon.webp',
  subdelta: '/subdelta.webp',
  zrc: '/zrc.jpg',
  bausele: '/bausele.jpg',
};

const brands = [
  { slug: 'squale', name: 'Squale', description: 'Swiss Made Professional Dive Watches of the highest quality, trusted by military professionals and athletes.' },
  { slug: 'marathon', name: 'Marathon', description: 'Allied forces timing instruments since 1941. Swiss engineering meets military-grade durability.' },
  { slug: 'subdelta', name: 'Subdelta', description: 'Authentic instrument watches built with uncompromising durability and refined aesthetics.' },
  { slug: 'zrc', name: 'ZRC', description: "Geneva's pioneering dive watch brand since 1904. Heritage meets technical excellence." },
  { slug: 'bausele', name: 'Bausele', description: 'Swiss-made watches with Australian soul. Founded 2011, featuring unique elements in every crown.' },
];
---

<Layout title="24-7-quality-time | Precision in Time. Excellence in Movement.">
  <!-- Hero Section -->
  <section 
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
    aria-labelledby="hero-heading"
  >
    <!-- Background Image -->
    <img
      src="/hero.jpg"
      alt="Luxury instrument watch close-up"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <!-- Dark Overlay -->
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(11, 38, 68, 0.82) 0%, rgba(11, 38, 68, 0.65) 50%, rgba(11, 38, 68, 0.45) 100%);" aria-hidden="true"></div>
    
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 
        id="hero-heading"
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-tight mb-6 drop-shadow-lg"
        style="text-shadow: 0 4px 20px rgba(0,0,0,0.6);"
      >
        Precision in Time.<br />
        <span class="text-white/95">Excellence in Movement.</span>
      </h1>
      <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 font-light drop-shadow-md"
         style="text-shadow: 0 2px 12px rgba(0,0,0,0.5);">
        Luxury Watches | European Distribution | Logistics & Fulfillment
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-primary bg-white rounded-lg hover:bg-white/90 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary"
      >
        Partner With Us
      </a>
    </div>
  </section>

  <!-- About Us Section -->
  <section class="py-24 bg-background" aria-labelledby="about-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Image -->
        <div class="relative">
          <img
            src="/aboutus.jpg"
            alt="24-7-quality-time headquarters and showroom"
            class="w-full rounded-2xl shadow-xl object-cover aspect-[4/3]"
            loading="lazy"
            decoding="async"
          />
        </div>
        
        <!-- Right: Text -->
        <div>
          <h2 id="about-heading" class="text-3xl sm:text-4xl font-bold text-primary mb-6">
            About 24-7-quality-time
          </h2>
          <div class="space-y-4 text-text/80 leading-relaxed">
            <p>
              Headquartered in Emsbüren, Germany, 24-7-quality-time operates under TMPCS.EU as a premier partner for luxury instrument watch brands seeking to establish and expand their presence across Europe.
            </p>
            <p>
              We specialize in the import, wholesale distribution, logistics, and fulfillment of exceptional Swiss and German timepieces. Our curated portfolio represents the pinnacle of precision engineering and horological heritage.
            </p>
            <p>
              From bonded warehousing to B2B and B2C fulfillment, we provide end-to-end solutions that allow watch brands to focus on what they do best—crafting extraordinary timepieces—while we ensure they reach the right hands across the continent.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Portfolio Section -->
  <section class="py-24 bg-white" aria-labelledby="brands-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 id="brands-heading" class="text-3xl sm:text-4xl font-bold text-primary mb-4">
          Our Brand Portfolio
        </h2>
        <p class="text-text/60 max-w-2xl mx-auto text-lg">
          We represent a distinguished collection of instrument watch brands, each with a unique story of precision and heritage.
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {brands.map((brand) => (
          <a 
            href={`/brands/${brand.slug}`} 
            class="group relative bg-background border border-secondary/20 rounded-xl overflow-hidden hover:shadow-xl hover:scale-[1.02] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          >
            <div class="aspect-[16/10] w-full overflow-hidden">
              <img
                src={brandImageMap[brand.slug]}
                alt={`${brand.name} watch`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-primary mb-2">{brand.name}</h3>
              <p class="text-text/70 text-sm leading-relaxed">{brand.description}</p>
            </div>
          </a>
        ))}
        
        <!-- Sicura - Hidden/Draft -->
        <!-- 
        <a href="/brands/sicura" class="group relative bg-background border border-secondary/20 rounded-xl overflow-hidden hover:shadow-xl hover:scale-[1.02] transition-all duration-300">
          <div class="aspect-[16/10] w-full overflow-hidden bg-secondary/10 flex items-center justify-center">
            <span class="text-secondary text-sm font-medium">Image placeholder: Sicura</span>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-primary mb-2">Sicura</h3>
            <p class="text-text/70 text-sm leading-relaxed">A legendary name in watchmaking, preparing for its European return.</p>
          </div>
        </a>
        -->
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-24 bg-primary text-white" aria-labelledby="services-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 id="services-heading" class="text-3xl sm:text-4xl font-bold mb-4">
          Our Services
        </h2>
        <p class="text-white/70 max-w-2xl mx-auto text-lg">
          End-to-end solutions for luxury watch brands entering and expanding across the European market.
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- European Distribution -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-8 md:p-10">
          <div class="h-12 w-12 bg-white/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-semibold mb-4">European Distribution</h3>
          <p class="text-white/70 leading-relaxed mb-6">
            Strategic market entry and retail supply chain management across Europe. We bridge the gap between exceptional watch brands and discerning European retailers.
          </p>
          <ul class="space-y-3 text-white/70 text-sm">
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-white/50 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Market entry strategy & execution
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-white/50 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Retail supply chain partnerships
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-white/50 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              B2B wholesale distribution
            </li>
          </ul>
        </div>
        
        <!-- Fulfillment Services -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-8 md:p-10">
          <div class="h-12 w-12 bg-white/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <h3 class="text-2xl font-semibold mb-4">Fulfillment Services</h3>
          <p class="text-white/70 leading-relaxed mb-6">
            Secure bonded warehousing and precision fulfillment for both B2B and B2C channels. Your inventory, handled with the care it deserves.
          </p>
          <ul class="space-y-3 text-white/70 text-sm">
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-white/50 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Secure bonded warehousing
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-white/50 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              B2B & B2C order fulfillment
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-white/50 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Customs & logistics coordination
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="py-24 bg-background" aria-labelledby="cta-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="text-3xl sm:text-4xl md:text-5xl font-bold text-primary mb-6">
        Let's move time forward—together.
      </h2>
      <p class="text-text/60 text-lg mb-10 max-w-2xl mx-auto">
        Whether you are a brand seeking European expansion or a retailer looking for exceptional timepieces, we are here to make it happen.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary rounded-lg hover:bg-primary/90 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
      >
        Contact Our Team
      </a>
    </div>
  </section>
</Layout>
