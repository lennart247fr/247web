---
import Layout from '../layouts/Layout.astro';

const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<Layout 
  title="Contact | TMPCS.EU"
  description="Get in touch with TMPCS.EU. Partner with us for luxury watch distribution, logistics, and fulfillment across Europe."
>
  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 bg-primary" aria-labelledby="contact-heading">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-[#0a1f38]" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 id="contact-heading" class="text-3xl sm:text-4xl md:text-5xl font-bold text-white tracking-tight">
        Contact Our Team
      </h1>
      <p class="mt-4 text-lg text-white/70 max-w-2xl">
        We look forward to discussing how we can support your brand's European expansion or fulfill your retail needs.
      </p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="py-24 bg-background" aria-label="Contact information and form">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Left Column: Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-primary mb-8">Get in Touch</h2>
          
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="h-10 w-10 rounded-lg bg-primary/5 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-primary uppercase tracking-wider mb-1">Owner</h3>
                <p class="text-text/80">Lennart Buiks</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="h-10 w-10 rounded-lg bg-primary/5 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-primary uppercase tracking-wider mb-1">Address</h3>
                <address class="not-italic text-text/80">
                  Rosmarinstrasse 10<br />
                  48488 Emsbüren<br />
                  Germany
                </address>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="h-10 w-10 rounded-lg bg-primary/5 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-primary uppercase tracking-wider mb-1">Email</h3>
                <a href="mailto:info@tmpcs.eu" class="text-text/80 hover:text-primary transition-colors">info@tmpcs.eu</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="h-10 w-10 rounded-lg bg-primary/5 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-primary uppercase tracking-wider mb-1">Phone</h3>
                <a href="tel:+4959039359398" class="text-text/80 hover:text-primary transition-colors">+49 5903 9359398</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="h-10 w-10 rounded-lg bg-primary/5 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-primary uppercase tracking-wider mb-1">VAT ID</h3>
                <p class="text-text/80">DE260830187</p>
              </div>
            </div>
          </div>

          <div class="mt-12 pt-8 border-t border-secondary/20">
            <h3 class="text-sm font-semibold text-primary uppercase tracking-wider mb-4">Business Hours</h3>
            <p class="text-text/80 text-sm">
              Monday – Friday: 9:00 – 17:00 CET<br />
              <span class="text-text/50">Closed on weekends and German public holidays.</span>
            </p>
          </div>
        </div>

        <!-- Right Column: Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-primary mb-8">Send an Inquiry</h2>
          
          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
            novalidate
          >
            <!-- Web3Forms Access Key -->
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
            
            <!-- Honeypot field -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
            </div>

            <!-- Redirect after success -->
            <input type="hidden" name="redirect" value={Astro.url.origin + '/contact?success=true'} />

            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-primary mb-2">
                Name <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                class="w-full px-4 py-3 rounded-lg border border-secondary/30 bg-white text-text placeholder:text-secondary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                placeholder="Your full name"
                aria-required="true"
                aria-describedby="name-error"
              />
              <p class="mt-1 text-sm text-red-600 hidden" id="name-error">Please enter your name.</p>
            </div>

            <!-- Company -->
            <div>
              <label for="company" class="block text-sm font-medium text-primary mb-2">
                Company
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-3 rounded-lg border border-secondary/30 bg-white text-text placeholder:text-secondary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                placeholder="Your company name"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-primary mb-2">
                Email <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-secondary/30 bg-white text-text placeholder:text-secondary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                placeholder="you@company.com"
                aria-required="true"
                aria-describedby="email-error"
              />
              <p class="mt-1 text-sm text-red-600 hidden" id="email-error">Please enter a valid email address.</p>
            </div>

            <!-- Subject -->
            <div>
              <label for="subject" class="block text-sm font-medium text-primary mb-2">
                Subject <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-3 rounded-lg border border-secondary/30 bg-white text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                aria-required="true"
                aria-describedby="subject-error"
              >
                <option value="" disabled selected>Select a subject</option>
                <option value="Distribution">Distribution Inquiry</option>
                <option value="Retail">Retail Inquiry</option>
                <option value="Brand Partnership">Brand Partnership</option>
                <option value="Other">Other</option>
              </select>
              <p class="mt-1 text-sm text-red-600 hidden" id="subject-error">Please select a subject.</p>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-primary mb-2">
                Message <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                minlength="10"
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-secondary/30 bg-white text-text placeholder:text-secondary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-y"
                placeholder="Tell us about your inquiry..."
                aria-required="true"
                aria-describedby="message-error"
              ></textarea>
              <p class="mt-1 text-sm text-red-600 hidden" id="message-error">Please enter a message (at least 10 characters).</p>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              id="submit-btn"
              class="w-full inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary rounded-lg hover:bg-primary/90 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="btn-text">Send Message</span>
              <span id="btn-loading" class="hidden">Sending...</span>
            </button>

            <!-- Success Message -->
            <div
              id="success-message"
              class={`p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm ${Astro.url.searchParams.get('success') === 'true' ? '' : 'hidden'}`}
              role="status"
              aria-live="polite"
            >
              Thank you for your message. We will get back to you as soon as possible.
            </div>

            <!-- Error Message -->
            <div
              id="form-error-message"
              class="hidden p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm"
              role="alert"
              aria-live="assertive"
            >
              Something went wrong. Please try again or contact us directly at <a href="mailto:info@tmpcs.eu" class="underline">info@tmpcs.eu</a>.
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  (function() {
    // Check for success query param (from non-JS form submission redirect)
    if (window.location.search.includes('success=true')) {
      const successMsg = document.getElementById('success-message');
      successMsg?.classList.remove('hidden');
      successMsg?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      // Clean up URL
      if (window.history.replaceState) {
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    }

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const btnText = document.getElementById('btn-text');
    const btnLoading = document.getElementById('btn-loading');
    const successMessage = document.getElementById('success-message');
    const errorMessage = document.getElementById('form-error-message');

    function showFieldError(id: string, show: boolean) {
      const el = document.getElementById(id);
      if (el) {
        el.classList.toggle('hidden', !show);
      }
    }

    function validateEmail(email: string): boolean {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Clear previous errors
      showFieldError('name-error', false);
      showFieldError('email-error', false);
      showFieldError('subject-error', false);
      showFieldError('message-error', false);
      errorMessage?.classList.add('hidden');

      const formData = new FormData(form);
      const name = String(formData.get('name') || '').trim();
      const email = String(formData.get('email') || '').trim();
      const subject = String(formData.get('subject') || '');
      const message = String(formData.get('message') || '').trim();
      const botcheck = String(formData.get('botcheck') || '').trim();

      let hasError = false;

      if (name.length < 2) {
        showFieldError('name-error', true);
        hasError = true;
      }

      if (!validateEmail(email)) {
        showFieldError('email-error', true);
        hasError = true;
      }

      if (!subject) {
        showFieldError('subject-error', true);
        hasError = true;
      }

      if (message.length < 10) {
        showFieldError('message-error', true);
        hasError = true;
      }

      // Honeypot check
      if (botcheck) {
        console.warn('Honeypot triggered');
        return;
      }

      if (hasError) {
        // Focus first invalid field
        const firstError = form.querySelector('[aria-required="true"]:invalid') as HTMLElement | null;
        firstError?.focus();
        return;
      }

      // Show loading state
      submitBtn?.setAttribute('disabled', 'true');
      btnText?.classList.add('hidden');
      btnLoading?.classList.remove('hidden');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });

        if (response.ok) {
          form.reset();
          successMessage?.classList.remove('hidden');
          successMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error('Submission failed');
        }
      } catch {
        errorMessage?.classList.remove('hidden');
        errorMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } finally {
        submitBtn?.removeAttribute('disabled');
        btnText?.classList.remove('hidden');
        btnLoading?.classList.add('hidden');
      }
    });
  })();
</script>
