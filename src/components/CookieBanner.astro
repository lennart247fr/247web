---
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[100] bg-white border-t border-secondary/20 shadow-2xl transform translate-y-full transition-transform duration-500"
  role="dialog"
  aria-modal="false"
  aria-label="Cookie consent"
  aria-live="polite"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="flex-1">
        <h3 class="text-base font-semibold text-primary mb-2">Cookie Settings</h3>
        <p class="text-sm text-text/70 leading-relaxed max-w-3xl">
          We respect your privacy. This website uses only essential cookies required for basic functionality. 
          We do not use tracking cookies or share your data with third parties. 
          By clicking "Accept", you consent to the use of essential cookies. 
          You can decline without affecting your browsing experience.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3 shrink-0">
        <button
          type="button"
          id="cookie-decline"
          class="px-5 py-2.5 text-sm font-medium text-primary border border-primary/20 rounded-lg hover:bg-primary/5 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          Decline
        </button>
        <button
          type="button"
          id="cookie-accept"
          class="px-5 py-2.5 text-sm font-medium text-white bg-primary rounded-lg hover:bg-primary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          Accept Essential Cookies
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const STORAGE_KEY = 'tmpcs-cookie-consent';
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const declineBtn = document.getElementById('cookie-decline');

    function getConsent() {
      try {
        const stored = localStorage.getItem(STORAGE_KEY);
        return stored ? JSON.parse(stored) : null;
      } catch {
        return null;
      }
    }

    function setConsent(consent: boolean) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          consent,
          timestamp: new Date().toISOString(),
          version: '1.0'
        }));
      } catch {
        // Ignore storage errors
      }
    }

    function hideBanner() {
      banner?.classList.add('translate-y-full');
      banner?.classList.remove('translate-y-0');
      banner?.setAttribute('aria-hidden', 'true');
    }

    function showBanner() {
      banner?.classList.remove('translate-y-full');
      banner?.classList.add('translate-y-0');
      banner?.setAttribute('aria-hidden', 'false');
    }

    // Initialize
    const existing = getConsent();
    if (!existing) {
      // Show banner after a short delay for better UX
      setTimeout(showBanner, 1000);
    } else {
      hideBanner();
    }

    acceptBtn?.addEventListener('click', () => {
      setConsent(true);
      hideBanner();
    });

    declineBtn?.addEventListener('click', () => {
      setConsent(false);
      hideBanner();
    });
  })();
</script>
