---
const navLinks = [
  { label: 'Services', href: '/#services' },
  { label: 'News', href: '/news' },
  { label: 'Contact', href: '/contact' },
];

const brandLinks = [
  { label: 'Squale', href: '/brands/squale' },
  { label: 'Marathon', href: '/brands/marathon' },
  { label: 'Subdelta', href: '/brands/subdelta' },
  { label: 'Bausele', href: '/brands/bausele' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm transition-all duration-300"
  role="banner"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-28 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 focus:outline-none focus:ring-2 focus:ring-primary/50 rounded" aria-label="TMPCS.EU Home">
        <img
          src="/newlogo.jpg"
          alt="TMPCS.EU Logo"
          class="h-24 w-auto object-contain"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-1 text-primary/90 hover:text-primary font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50 rounded px-1"
            aria-haspopup="true"
            aria-expanded="false"
            id="brands-dropdown-btn"
          >
            Brands
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            class="absolute top-full left-0 mt-2 w-48 rounded-lg bg-white shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-left border border-secondary/10"
            role="menu"
            aria-labelledby="brands-dropdown-btn"
          >
            <div class="py-2">
              {brandLinks.map((brand) => (
                <a
                  href={brand.href}
                  class="block px-4 py-2 text-sm text-text hover:bg-primary hover:text-white transition-colors"
                  role="menuitem"
                >
                  {brand.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-primary/90 hover:text-primary font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50 rounded px-1"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-primary hover:bg-primary/10 focus:outline-none focus:ring-2 focus:ring-primary/50"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Toggle menu"
      >
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-secondary/10" role="menu">
    <div class="px-4 pt-2 pb-4 space-y-1">
      <p class="px-3 py-2 text-xs font-semibold text-primary/50 uppercase tracking-wider">Brands</p>
      {brandLinks.map((brand) => (
        <a
          href={brand.href}
          class="block px-3 py-2 rounded-md text-base font-medium text-primary/90 hover:bg-primary/10 hover:text-primary"
          role="menuitem"
        >
          {brand.label}
        </a>
      ))}
      <div class="border-t border-secondary/10 my-2"></div>
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-3 py-2 rounded-md text-base font-medium text-primary/90 hover:bg-primary/10 hover:text-primary"
          role="menuitem"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  (function() {
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    // Mobile toggle
    mobileBtn?.addEventListener('click', () => {
      const expanded = mobileBtn.getAttribute('aria-expanded') === 'true';
      mobileBtn.setAttribute('aria-expanded', String(!expanded));
      mobileMenu?.classList.toggle('hidden');
    });
  })();
</script>
